# ============================================================
# Zullya ERP — Variáveis de Ambiente (RAIZ)
# ============================================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA AS SENHAS!
# NUNCA comite o arquivo .env no Git.
# ============================================================

# ================================
# BANCO DE DADOS (PostgreSQL)
# ================================
DB_NAME=zullya_erp
DB_USER=zullya_erp_user
DB_PASSWORD=GERE_UMA_SENHA_FORTE_AQUI_MinhaS3nh@Fort3

# ================================
# REDIS
# ================================
REDIS_PASSWORD=GERE_UMA_SENHA_REDIS_FORTE_AQUI

# ================================
# JWT (JSON Web Token)
# ================================
# IMPORTANTE: Gere strings aleatórias de 64+ caracteres
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=COLE_AQUI_64_CARACTERES_ALEATORIOS
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=COLE_AQUI_OUTROS_64_CARACTERES_ALEATORIOS
JWT_REFRESH_EXPIRES_IN=30d

# ================================
# FRONTEND
# ================================
FRONTEND_URL=https://app.seudominio.com.br
VITE_API_URL=https://api.seudominio.com.br/api

# ================================
# RRPAY (Gateway de Pagamento)
# ================================
RRPAY_WEBHOOK_SECRET=SEU_WEBHOOK_SECRET_DO_PAINEL_RRPAY
RRPAY_API_KEY=SUA_API_KEY_DO_PAINEL_RRPAY
RRPAY_BASE_URL=https://api.rrpay.com.br/v1

# ================================
# BACKUP AUTOMÁTICO
# Opção A: Backblaze B2 (mais barato)
# Opção B: AWS S3
# ================================
BACKUP_ENCRYPTION_PASSPHRASE=FRASE_PARA_CRIPTOGRAFAR_BACKUPS
BACKUP_S3_BUCKET=nome-do-seu-bucket
BACKUP_S3_REGION=us-west-004
BACKUP_S3_ACCESS_KEY=SUA_BACKBLAZE_KEY_ID
BACKUP_S3_SECRET_KEY=SUA_BACKBLAZE_APPLICATION_KEY
# Para Backblaze B2:
BACKUP_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# Para AWS S3: deixe BACKUP_S3_ENDPOINT em branco
