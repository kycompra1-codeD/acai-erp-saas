# ================================
# DATABASE (PostgreSQL)
# ================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=acai_erp
DB_USER=acai_erp_user
DB_PASSWORD=TROQUE_ESTA_SENHA_FORTE_AQUI

# ================================
# REDIS
# ================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=TROQUE_REDIS_SENHA_AQUI

# ================================
# JWT (JSON Web Token)
# ================================
JWT_SECRET=TROQUE_JWT_SECRET_MINIMO_64_CARACTERES_AQUI_xKy92!
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=TROQUE_JWT_REFRESH_SECRET_MINIMO_64_CARACTERES_AQUI
JWT_REFRESH_EXPIRES_IN=30d

# ================================
# SERVIDOR
# ================================
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://app.seuerp.com

# ================================
# RRPAY (Gateway de Pagamento)
# ================================
RRPAY_WEBHOOK_SECRET=SEU_WEBHOOK_SECRET_RRPAY
RRPAY_API_KEY=SUA_API_KEY_RRPAY
RRPAY_BASE_URL=https://api.rrpay.com.br/v1

# ================================
# BACKUP (Escolha um provedor)
# ================================
# Opção A: AWS S3 / Backblaze B2 (compatível com S3)
BACKUP_S3_BUCKET=nome-do-seu-bucket
BACKUP_S3_REGION=sa-east-1
BACKUP_S3_ACCESS_KEY=SUA_ACCESS_KEY
BACKUP_S3_SECRET_KEY=SUA_SECRET_KEY
BACKUP_S3_ENDPOINT=https://s3.amazonaws.com  # ou endpoint do Backblaze

# ================================
# EMAIL (para notificações e recuperação de senha)
# ================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app_gmail
EMAIL_FROM="Açaí ERP <noreply@seuerp.com>"
